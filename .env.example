# Global City Intelligence — environment variables
# Copy to .env.local for local development; set the same keys in the
# production environment (e.g. Vercel project settings).

# Public site origin (no trailing slash). Used for canonical URLs, the
# sitemap, robots.txt, and as the IndexNow host. Defaults to
# https://www.globalcityintelligence.com when unset.
NEXT_PUBLIC_SITE_URL=https://www.globalcityintelligence.com

# IndexNow API key. The matching key file must be served at
# https://<host>/<INDEXNOW_KEY>.txt (see public/857a708c8e384b8aba2c7cc155a5e350.txt).
# Used by lib/seo/indexnow.ts and scripts/submit-indexnow.mjs to notify
# search engines of new/updated URLs. NEVER submitted during build —
# run the CLI manually or in a post-deploy step.
INDEXNOW_KEY=857a708c8e384b8aba2c7cc155a5e350
